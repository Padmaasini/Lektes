# TalentMesh Environment Variables
# Copy this to .env and fill in your values

# LLM (Gemini - Free)
# Get your free key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# LinkedIn (Free - uses linkedin-api library)
# Create a SECONDARY LinkedIn account for this
LINKEDIN_USERNAME=your_secondary_linkedin_email
LINKEDIN_PASSWORD=your_secondary_linkedin_password

# GitHub (Free)
# Get token at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Email (Free - Gmail SMTP)
# Use Gmail App Password NOT your regular password
# Enable at: https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# App Settings
DEBUG=False
DATABASE_URL=sqlite:///./talentmesh.db
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads
